@article{ WOS:001424975300001,
Author = {Chen, Changjie and Han, Yu and Galinski, Andrea and Calle, Christian and
   Carney, Jeffrey and Ye, Xinyue and van Westen, Cees},
Title = {Integrating Urban Digital Twin with Cloud-Based Geospatial Dashboard for
   Coastal Resilience Planning: A Case Study in Florida},
Journal = {JOURNAL OF PLANNING EDUCATION AND RESEARCH},
Year = {2025},
Volume = {45},
Number = {4, SI},
Pages = {743-759},
Month = {DEC},
Abstract = {Coastal communities are confronted with a growing incidence of
   climate-induced flooding, necessitating adaptation measures for
   resilience. In this paper, we introduce a framework that integrates an
   urban digital twin with a geospatial dashboard to allow visualization of
   the vulnerabilities within critical infrastructure across a range of
   spatial and temporal scales. The synergy between these two technologies
   fosters heightened community awareness about increased flood risks to
   establish a unified understanding, the foundation for collective
   decision-making in adaptation plans. The paper also elucidates ethical
   considerations while developing the platform, including ensuring
   accessibility, promoting transparency and equity, and safeguarding
   individual privacy.},
