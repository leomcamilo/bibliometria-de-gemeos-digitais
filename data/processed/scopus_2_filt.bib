	coden = {JMENE},
	language = {English},
	abbrev_source_title = {J Manage Eng},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 8}
}


@ARTICLE{Belfadel2023,
	author = {Belfadel, Abdelhadi and Hörl, Sebastian and Tapia, Rodrigo Javier and Politaki, Dimitra and Kureshi, Ibad and Tavasszy, Lorant and Puchinger, Jakob},
	title = {A conceptual digital twin framework for city logistics},
	year = {2023},
