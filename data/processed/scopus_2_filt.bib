}


@ARTICLE{Korkmaz2025,
	author = {Korkmaz, Mustafa and Akyildiz, Yasemin Ezgi and Demirkesen, Sevilay and Toprak, Selcuk and Nowak, Paweł and Ciftci, Bunyamin},
	title = {A Digital Twin Approach to Sustainable Disaster Management: Case of Cayirova},
	year = {2025},
	journal = {Sustainability (Switzerland)},
	volume = {17},
