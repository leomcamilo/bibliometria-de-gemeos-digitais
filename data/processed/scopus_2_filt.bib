	keywords = {Building components; Metadata; Network security; Bi-directional; Building digital twin; Built environment; City digital twin; Directional data; Language processing; LLM; Natural language processing; Natural languages; Urban digital twin; architectural design; conceptual framework; digitization; literature review; real time; research work; technology adoption; terminology; urban area; urban geography; Natural language processing systems},
