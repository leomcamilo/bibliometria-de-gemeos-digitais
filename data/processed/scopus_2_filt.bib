	doi = {10.1016/j.uclim.2025.102715},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105023659081&doi=10.1016%2Fj.uclim.2025.102715&partnerID=40&md5=596200f6ee8527372ceb0ff848232108},
	affiliations = {College of Art & Design, Nanjing Forestry University, Nanjing, 210037, China; College of Art and Design, Wuhan Institute of Technology, Wuhan, 430205, China; Department of Living Environment Design, of Human Life and Ecology, Osaka Metropolitan University, Osaka, 558-8585, Japan; Jinpu Research institute, Nanjing Forestry University, Nanjing, 210037, China},
	abstract = {In response to the increasing frequency of extreme weather events globally, the Chinese government has proposed the dual‑carbon strategy to mitigate climate change. In this context, optimizing human body comfort and carbon sink capacity has become integral to urban green space design. This study proposes that digital twin design offers a viable framework for future urban carbon sink green space planning. By establishing a digital twin platform, this study utilizes Virtual Reality (VR) to facilitate real-time monitoring of Carbon Sink Capacity (CSC), the Discomfort Index (DI), as well as participants' Eye Movement Interest (EMI) and Skin Conductance Level (SCL) across various Areas of Interest (AOI). The findings indicate that: (1) CSC of different AOI exhibit a positive correlation with the participants' EMI; (2) the participants' level of EMI in different AOI is inversely correlated with SCL; and (3) the participants' SCL in different AOI is positively correlated with DI under human thermal sensation. The research results demonstrate that digital twin platform can be effectively applied to urban green space functional evaluation, providing practical design recommendations conducive to urban carbon sink optimization and achieving dual carbon goals. © 2025 Elsevier B.V.},
