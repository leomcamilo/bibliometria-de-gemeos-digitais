	year = {2025},
	journal = {Urban Climate},
	volume = {62},
	pages = {},
	doi = {10.1016/j.uclim.2025.102530},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009748876&doi=10.1016%2Fj.uclim.2025.102530&partnerID=40&md5=419baeab3bb5c05d62f931d32e7ace1d},
	affiliations = {GATE Institute, Sofia University “St. Kliment Ohridski”, Sofia, 1164, Bulgaria},
	abstract = {Urban Digital Twin (UDT) provides knowledge and technologies for data-driven decision support for a broad group of stakeholders towards developing sustainable cities and communities. However, its implementation is associated with several problems, including data integration and quality, model complexity and uncertainty, computational resources, spatial and temporal resolution, and validation. Addressing these challenges requires innovative technological solutions and development efforts in the fields of urban modelling and digital twin technologies. This study proposes an approach for performing climate simulations using the state-of-the-art Weather Research & Forecasting Model (WRF) and integration of the results with very high resolution, representing the relevant features of air temperature distributions over a wide area, within an UDT. The impacts of Urban Heat Islands (UHIs) on air temperatures were investigated, analysed and visualised based on data collected from heterogeneous sources in Sofia City, Bulgaria. The results show a strong UHI effect on temperature of around 6.0 °C in the central part of the city compared to the suburbs at 2100 Local Standard Time (LST) in August 2018, due to urbanisation and energy consumption from buildings. The study indicates that areas experiencing an increase in temperature and energy consumption require high attention and the implementation of feasible measures. © 2025 The Authors},
	author_keywords = {Buildings; Temperature; UHI; Urban climate; Urban digital twin; WRF model},
	correspondence_address = {L. Vitanova; GATE Institute, Sofia University “St. Kliment Ohridski”, Sofia, 1164, Bulgaria; email: lidia.vitanova@gate-ai.eu},
