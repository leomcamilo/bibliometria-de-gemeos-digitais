	author = {García-Aranda, César and Martínez-Cuevas, Sandra and Torres, Yolanda and Pedrote Sanz, María},
	title = {A Digital Twin of a University Campus from an Urban Sustainability Approach: Case Study in Madrid (Spain)},
	year = {2024},
