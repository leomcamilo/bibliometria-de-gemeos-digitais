@article{ WOS:001516210500004,
Author = {Ziari, Keramatollah and Dorostkar, Ehsan},
Title = {The role of metaverse in urban planning: A geospatial framework for
   simulating sustainable and resilient cities},
Journal = {SUSTAINABLE FUTURES},
Year = {2025},
Volume = {10},
Month = {DEC},
Abstract = {Research topic: The use of metaverse technologies (digital twins, AI,
   VR/AR) for urban planning is the subject of this research. Significance:
   Rapid urbanization demands responses to sustainability and resilience
   that exceed traditional planning. Objective(s): We want to discuss
   metaverse uses in urban planning, investigate the role of geospatial
   technologies, reveal integration challenges/opportunities, and suggest a
   conceptual geospatialmetaverse framework. Originality: This is the first
   framework that combines geospatial analytics, participatory simulations,
   and artificial intelligence-driven predictive modeling in the metaverse
   to enable integrated urban planning. Methodology: A tripartite
   conceptual framework (spatial analytics, virtual city representation,
   stakeholder collaboration) leverages geospatial data (remote sensing,
   GIS, IoT, metaverse interactions) and AI algorithms. Findings: Metaverse
   enables real-time policy testing, resilience modeling for disasters, and
   inclusive citizen participation; Data interoperability and digital
   equity are binding constraints; Interdisciplinary collaboration is a
   driver of scalability. Practical applications: City policymakers can
   utilize this framework to achieve optimum utilization of land, enable
   simplified climate adaptation and evidence-based governance.},
Publisher = {ELSEVIER},
