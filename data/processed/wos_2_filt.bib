@article{ WOS:001581463200001,
Author = {Velasquez-Mendez, Augusto and Lozoya-Santos, Jorge de Jesus and
   Jimenez-Vargas, Jose Fernando},
Title = {Validating a Sustainable, Smart, and Circular City Architecture Through
   Urban Living Lab Experiments},
Journal = {URBAN SCIENCE},
