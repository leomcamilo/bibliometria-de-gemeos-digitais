@article{ WOS:001621495500001,
Author = {Faraji, Amir and Homayoon Arya, Shima and Ghasemi, Elnaz and Abagheri
   Mahabadi, Hannan and Perera, Srinath},
Title = {Exploring the metaverse: integrating emerging technologies for Industry
   5.0 advancement},
Journal = {SMART AND SUSTAINABLE BUILT ENVIRONMENT},
Year = {2025},
Month = {2025 NOV 25},
Abstract = {PurposeThis paper aims to explore the application of the Metaverse in
   the construction industry through an in-depth literature review. It
   highlights the core enabling technologies and investigates how they
   contribute to creating immersive, intelligent and sustainable
   construction practices in line with Industry 5.0 ideals.
   Design/methodology/approachThis study utilizes a systematic literature
   review methodology, examining 194 peer-reviewed articles published from
   2015 to 2024. The papers were selected from top academic databases using
   specific inclusion and exclusion criteria. The review centers on
   Metaverse applications, the foundational technologies involved and their
   influence on various aspects of the construction industry. FindingsThe
   results highlight the growing scholarly interest in the application of
   Metaverse technologies in the building sector, which has grown
   significantly since 2021. Key technologies identified include augmented
   reality, virtual reality, mixed reality, extended reality (XR), building
   information modeling, Digital Twin, the Internet of Things, artificial
   intelligence and blockchain technology (BCT). These technologies
   facilitate real-time collaboration, immersive visual environments,
   secure data exchange and smart decision-making processes. Seven major
   areas of the construction industry - project management, architectural
   design, urban planning, construction education, civil engineering,
   energy management and supply chain coordination - are seeing a surge in
   innovation because of the Metaverse. Full integration is nevertheless
   hindered by persistent issues with data privacy, interoperability and
   regulatory uncertainty, despite its potential. Practical
   implicationsThis study provides practical insights for industry
   stakeholders aiming to leverage Metaverse technologies for digital
   transformation in construction. It emphasizes the need for integrated
   frameworks, skilled workforce development and consideration of
   environmental and economic impacts. Originality/valueThis paper offers a
   novel synthesis of current literature at the intersection of Metaverse
   technologies and construction, highlighting research gaps and suggesting
   directions for future exploration. It contributes to the theoretical and
   practical understanding of how Metaverse adoption can drive smart,
   sustainable and human-centric innovation in the construction industry.},
