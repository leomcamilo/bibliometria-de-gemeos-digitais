@article{ WOS:001634001000001,
Author = {Lin, Zhengsong and Ji, Zhe and Yuan, Jihui and Zhu, Zunling},
Title = {Research on emotional perception and human comfort evaluation of carbon
   sequestration landscape design based on digital twin technology},
Journal = {URBAN CLIMATE},
Year = {2025},
Volume = {64},
Month = {DEC},
Abstract = {In response to the increasing frequency of extreme weather events
   globally, the Chinese government has proposed the dual-carbon strategy
   to mitigate climate change. In this context, optimizing human body
   comfort and carbon sink capacity has become integral to urban green
   space design. This study proposes that digital twin design offers a
   viable framework for future urban carbon sink green space planning. By
   establishing a digital twin platform, this study utilizes Virtual
   Reality (VR) to facilitate real-time monitoring of Carbon Sink Capacity
   (CSC), the Discomfort Index (DI), as well as participants' Eye Movement
   Interest (EMI) and Skin Conductance Level (SCL) across various Areas of
   Interest (AOI). The findings indicate that: (1) CSC of different AOI
   exhibit a positive correlation with the participants' EMI; (2) the
   participants' level of EMI in different AOI is inversely correlated with
   SCL; and (3) the participants' SCL in different AOI is positively
   correlated with DI under human thermal sensation. The research results
   demonstrate that digital twin platform can be effectively applied to
   urban green space functional evaluation, providing practical design
   recommendations conducive to urban carbon sink optimization and
   achieving dual carbon goals.},
