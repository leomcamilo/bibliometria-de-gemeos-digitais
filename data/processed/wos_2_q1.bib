Title = {Urban revitalization pathways toward zero carbon emissions through
   systems architecting of urban digital twins},
Journal = {ENVIRONMENT AND PLANNING B-URBAN ANALYTICS AND CITY SCIENCE},
Year = {2025},
Volume = {52},
