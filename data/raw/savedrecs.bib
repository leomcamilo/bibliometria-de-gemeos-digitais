@article{ WOS:000918276500001,
Author = {Saddiqi, M. Matin and Zhao, Wanqing and Cotterill, Sarah and Dereli,
   Recep Kaan},
Title = {Smart management of combined sewer overflows: From an ancient technology
   to artificial intelligence},
Journal = {WILEY INTERDISCIPLINARY REVIEWS-WATER},
