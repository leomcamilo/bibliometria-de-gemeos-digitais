@article{ WOS:001281643900001,
Author = {Allan, Mark and Rajabifard, Abbas and Foliente, Greg},
Title = {Climate resilient urban regeneration and SDG 11-stakeholders' view on
   pathways and digital infrastructures},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2024},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {Urban areas grapple with escalating challenges due to climate change,
   rapid urbanisation, and shifting demographics. Collaborative efforts and
   innovative applications of big earth data analytics and digital
   infrastructures are imperative in tackling the issues facing cities and
   advancing SDG 11.Modernising urban infrastructure is essential, coupled
   with a focus on people-centric urban regeneration to enhance the
   well-being of city residents. Urban resilience, encompassing diverse
   social, economic, environmental, and governance facets, lies at the core
   of this mission. A resilient city can endure and recover from
   disruptions, be they natural disasters or human-made crises.Stakeholder
   engagement, bridging top-down and bottom-up approaches, is pivotal in
   fostering the use of earth data to promote sustainability and urban
   resilience. A literature review and on-going research underscores
   digital infrastructure's potential in fortifying resilient, sustainable
   cities. Insights from an international forum on `Digital Infrastructure
   for Climate Resilience' held in Melbourne, Australia in 2023 inform this
   perspective.Big earth data analytics combined with Urban Digital Twin
   technologies, emerge as potent tools for urban stakeholders and
   decision-makers. Despite challenges, opportunities abound to leverage
   data and digital platforms to bolster sustainable urban development.
   Effective leadership, government regulations, standards, and
   cross-sector collaboration are essential for realising this potential.},
