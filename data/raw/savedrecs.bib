@article{ WOS:001201016000001,
Author = {del Campo, Guillermo and Saavedra, Edgar and Piovano, Luca and Luque,
   Francisco and Santamaria, Asuncion},
Title = {Virtual Reality and Internet of Things Based Digital Twin for Smart City
   Cross-Domain Interoperability},
