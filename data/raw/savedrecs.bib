@article{ WOS:001694401800001,
Author = {Divya, A. and Ramesh, S. and Chakrasali, Sadashiva V. and Kumar, Meriga
   Kiran and Taj, Mohammad and Ganiya, Rajendra Kumar and Rao, J. Nageswara
   and Balasubramanian, K. and Qamar, Shamimul},
Title = {Federated digital-twin-empowered blockchain architecture for autonomous
   and resilient smart water management in sustainable cities},
Journal = {SUSTAINABLE COMPUTING-INFORMATICS \& SYSTEMS},
Year = {2026},
Volume = {50},
Month = {JUN},
Abstract = {As urban waterscapes face mounting pressures from climate change and
   rapid urbanization, innovative frameworks are needed to ensure
   resilience, fairness, and sustainability. This paper introduces the
   Fodba architecture for autonomous and adaptive water resource management
   in future sustainable cities, built upon FDTB principles. The system
   integrates real-time IoT sensing with federated machine learning at the
   edge, enabling privacypreserving collaboration among intermediate
   gateways without sharing raw customer data. All data is maintained on a
   blockchain substrate, ensuring protection without the need for
   censorship, revocation, or temporal traceability, while smart contracts
   enforce equitable resource allocation policies. Central to the
   architecture is a digital twin of the water system, continuously updated
   with sensor telemetry and blockchain-anchored events. This twin allows
   proactive anticipation of bursts and resource depletion, resilience
   stress-testing, and selforganized water distribution reformation. We
   validated Fodba in AquaCity-25, an emulated smart city with 10,000 IoT
   water sensors, 5000 households with Bitcoin wallets, and 25 blockchain
   validator nodes. Results show a 27.6 \% reduction in non-revenue water
   and a 14.3 \% improvement in demand prediction accuracy over baseline
   LSTM models. Blockchain transaction finality is achieved within 150 ms
   at p95 latency. Fairness indices remain above 0.92 under variable
   demand, while federated learning reduces raw data transmissions by 61
   \%, preserving privacy and energy efficiency. By uniting blockchain,
   federated intelligence, and digital-twin simulation, Fodba offers a
   blueprint for autonomous, resilient, and ethical urban water
   infrastructures. The architecture demonstrates a model for transparent
   governance, climate-ready utilities, and digitally resilient smart
   cities.},
