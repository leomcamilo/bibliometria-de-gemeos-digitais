@article{ WOS:001696973800037,
Author = {Hajtmanek, Roman and Uhrik, Martin and Hain, Vladimir},
Title = {UrbanGraphica: Digital Twin for Estimation of Public Spaces Quality},
Journal = {INZYNIERIA MINERALNA-JOURNAL OF THE POLISH MINERAL ENGINEERING SOCIETY},
Year = {2024},
Number = {2},
