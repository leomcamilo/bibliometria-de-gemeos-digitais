   Argota Sanchez-Vaquerizo, Javier, Swiss Fed Inst Technol, Computat Social Sci, D GESS, Stampfenbachstr 48, CH-8092 Zurich, Switzerland.},
DOI = {10.1007/s10676-024-09812-3},
Article-Number = {4},
ISSN = {1388-1957},
EISSN = {1572-8439},
