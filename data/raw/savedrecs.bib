@article{ WOS:001578885600001,
Author = {Zhang, Yaqi and Ji, Chunyu and Ye, Jing and Zou, Heng and Peng, Lanjia},
Title = {Architectural identity in smart city development: a multi-criteria study
   on regional culture in northeastern China},
Journal = {JOURNAL OF ASIAN ARCHITECTURE AND BUILDING ENGINEERING},
Year = {2025},
Month = {2025 SEP 27},
Abstract = {In northern China, smart city infrastructure development is directly
   affected by the cultural aspects of the region, and there is a need for
   a futuristic strategy to make decisions that complement tradition with
   technology. The current study attempts to show the way how MCDM
   frameworks and digital twin technology are combined to influence urban
   planning and infrastructure optimization concerning cultural issues. The
   current study is about how regional culture influences smart city
   infrastructure development in northeastern China through a survey-based
   approach. This research study investigates how cultural values,
   governance models, and socio-economic conditions influence smart city
   development by collecting information from urban planners, policymakers,
   architects, and residents of key cities. The questionnaire aimed to
   identify stakeholder perceptions regarding integrating traditional
   architectural elements, local institutional frameworks, and new
   technologies, such as digital twins and artificial intelligence, into
   urban planning. The study employs multi-criteria decision-making (MCDM)
   methods to examine the importance of relevance and cultural weightage in
   the selection of a decision-making framework for development that is
   aimed at optimizing infrastructure, sustainability, and efficiency.
   Surveys confirm technology acceptance, but preference toward regional
   identity through adaptive strategies takes precedence in urban planning.
   This research shows how computational intelligence aids the differential
   urban transformation under uncertainty pertaining to decision-making
   while keeping an eye on culture. Challenges confronting the smart city
   development processes in the region are those such as change management,
   gaps in policy, and technological accessibility. The findings suggest
   that the MCDM's hybrid decision support systems with stakeholder
   consultations could enhance smart city project formulation without
   compromising heritage.},
