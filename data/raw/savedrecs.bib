@article{ WOS:001447564700001,
Author = {Bahreldin, Ibrahim and Samir, Hossam and Maddah, Rahif and Hammad, Hazem
   and Hegazy, Ibrahim},
Title = {Leveraging advanced digital technologies for smart city development in
   Saudi Arabia: opportunities, challenges, and strategic pathways},
Journal = {INTERNATIONAL JOURNAL OF LOW-CARBON TECHNOLOGIES},
Year = {2025},
Volume = {20},
Pages = {834-847},
Month = {MAR 20},
Abstract = {Advanced digital technologies, including Urban Digital Twins (UDTs), are
   transformative for smart city development, offering solutions to
   mitigate climate change and enhance urban management. This study
   examines UDT integration within Saudi Arabia's Vision 2030, focusing on
   optimizing energy consumption, improving smart grid operations, and
   adopting renewable energy systems. Using a literature review, case
   studies, and stakeholder consultations, it identifies key opportunities
   and challenges, including data security and infrastructure readiness.
   Insights from global examples contextualize UDTs' role in sustainable
   urban development, showcasing integration with low-carbon technologies.
   The study provides actionable strategies to position Saudi Arabia as a
   leader in resilient cities.},
