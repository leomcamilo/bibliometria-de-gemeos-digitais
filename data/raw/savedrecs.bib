@article{ WOS:000748485500001,
Author = {Charitonidou, Marianna},
Title = {Urban scale digital twins in data-driven society: Challenging digital
   universalism in urban planning decision-making},
Journal = {INTERNATIONAL JOURNAL OF ARCHITECTURAL COMPUTING},
Year = {2022},
Volume = {20},
Number = {2},
Pages = {238-253},
Month = {JUN},
Abstract = {The article examines the impact of the virtual public sphere on how
   urban spaces are experienced and conceived in our data-driven society.
   It places particular emphasis on urban scale digital twins, which are
   virtual replicas of cities that are used to simulate environments and
   develop scenarios in response to policy problems. The article also
   investigates the shift from the technical to the socio-technical
   perspective within the field of smart cities. Despite the aspirations of
   urban scale digital twins to enhance the participation of citizens in
   the decision-making processes relayed to urban planning strategies, the
   fact that they are based on a limited set of variables and processes
   makes them problematic. The article aims to shed light on the tension
   between the real and the ideal at stake during this process of
   abstracting sets of variables and processes in the case of urban scale
   digital twins.},
