@article{ WOS:001645355500013,
Author = {Maswadi, Kholoud},
Title = {Intelligent Traffic Management in Information System: A Dual-Graph
   Convolutional Approach With Holographic Digital Twins and IoT
   Integration},
Journal = {IEEE TRANSACTIONS ON CONSUMER ELECTRONICS},
Year = {2025},
Volume = {71},
Number = {4},
Pages = {11453-11464},
Month = {NOV},
Abstract = {The growing integration of IoT consumer electronics into urban
   infrastructure has led to the generation of vast amounts of real-time
   data from traffic sensors, weather stations, and connected devices. By
   combining traffic flow information with weather conditions and their
   holographic digital twin counterparts, cities can improve congestion
   management under varying environmental scenarios. However, most existing
   traffic flow prediction models overlook the latent spatial relationships
   within transportation networks and fail to address prediction errors
   caused by external factors such as weather, reducing forecast accuracy.
   To overcome these limitations, this paper introduces the Holographic
   Digital Twin Graph Convolutional Network (HDT-GCN), a dual-graph
   convolution framework built on Temporal Convolutional Networks (TCNs) to
   fuse traffic flow and weather features into an augmented representation.
   This approach jointly models temporal dependencies, spatial
   correlations, and dynamic inter-regional interactions, while mitigating
   the negative impact of complex weather patterns on prediction outcomes.
   The incorporation of holographic digital twins enhances system
   visualization, real-time decision-making, and interactive accessibility
   through IoT consumer devices. Extensive experiments on the real-world
   TaxiBJ and PeMSD4 datasets demonstrate that HDT-GCN achieves superior
   prediction accuracy and robustness compared to state-of-the-art methods.},
Publisher = {IEEE-INST ELECTRICAL ELECTRONICS ENGINEERS INC},
Address = {445 HOES LANE, PISCATAWAY, NJ 08855-4141 USA},
