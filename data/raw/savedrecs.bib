@article{ WOS:001627447000004,
Author = {Habe, Behailu Temesgen},
Title = {Explainable digital twins for circular construction: A systematic review
   of real-time decision-making and urban retrofitting frameworks},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2025},
Volume = {116},
Month = {DEC 15},
Abstract = {Digital twins (DTs) are increasingly deployed in the built environment
   to enable real-time monitoring, predictive analytics, and informed
   decision-making within complex urban systems. When integrated with
   artificial intelligence (AI), DTs can optimize performance and lifecycle
   outcomes; however, the opacity of AI algorithms often limits
   transparency, trust, and regulatory compliance. This targeted systematic
   review investigates how DTs, Explainable AI (XAI), and circular
   construction principles intersect to advance sustainable and accountable
   infrastructure. Following a PRISMA-guided protocol, twenty-five
   peer-reviewed studies published between 2017 and 2025 (including
   in-press articles) were selected from an initial pool of 1750 records.
   The synthesis spans four thematic dimensions: (1) DT applications for
   real-time decision-support in retrofitting and circular construction;
   (2) XAI techniques - such as SHAP, LIME, and Scene2Model - for
   interpretable and trustworthy analytics; (3) lifecycle and
   material-reuse strategies aligned with circular-economy goals; and (4)
   implementation challenges related to interoperability, policy
   fragmentation, and scalability. The review formulates a structured
   research agenda emphasizing open data standards, human-in-the-loop
   design, and governance mechanisms to institutionalize explainability
   within digital-twin ecosystems. By articulating how transparency can be
   embedded into data-driven construction processes, this study delineates
   a pathway toward verifiable, adaptive, and circular urban
   infrastructure.},
Publisher = {ELSEVIER},
Address = {RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS},
Type = {Article},
Language = {English},
