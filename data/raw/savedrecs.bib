@article{ WOS:001607402600001,
Author = {Shariatpour, Farshad and Behzadfar, Mostafa and Jalilisadrabad, Samaneh},
Title = {A socio-technical framework for urban digital twins: Tehran in a global
   comparison},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {134},
Month = {NOV 15},
Abstract = {The concurrent growth of big data and the Internet of Things (IoT) has
   transformed the urban digital twin into a key tool for planning, design,
   and management. Yet the gap between technical infrastructure and
   effective citizen participation remains under-addressed. We ask: (1)
   which technical and social factors determine the efficiency of urban
   digital twins, and how these align with Arnstein's participation ladder;
   and (2) how Tehran compares with leading cities in socio-technical
   convergence. We conduct a systematic review of 84 sources to derive a
   two-dimensional framework linking three clusters-data and
   infrastructure, structural openness, and participation level-and define
   twelve indicators weighted via the Analytic Hierarchy Process (AHP). We
   apply the index to nine city-scale twins and then run robustness checks
   (equal-weight, policy-priority, leave-one-out), which yield rank-order
   correlations > 0.90, indicating stable comparative findings. Results
   place Singapore (8.7/10) and Zurich (8.2/10) at the top and Tehran at
   4.1, with the largest gaps in open-data governance and participation. We
   propose a context-sensitive roadmap for Tehran that combines (i) an open
   3D data portal, (ii) participatory APIs and low-cost sensing, and (iii)
   interactive scenario tools, together with digital-literacy programs,
   privacy-by-design, and trust-building governance. Arnstein's ladder is
   treated as a heuristic adapted to Tehran's context. Overall, the full
   potential of urban digital twins is realized only when investments in
   data infrastructure advance in tandem with transparent governance and
   citizen empowerment to deliver sustainability outcomes.},
