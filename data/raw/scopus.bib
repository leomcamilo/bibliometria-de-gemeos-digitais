	pages = {},
	doi = {10.1016/j.jenvman.2023.118389},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85163759945&doi=10.1016%2Fj.jenvman.2023.118389&partnerID=40&md5=d79a16d5be15607d3f7cb935ef3e8f24},
	affiliations = {Faculty of Applied Science, Delft University of Technology, Netherlands; IHE Delft Institute for Water Education, Netherlands; Faculty of Civil Engineering, University of Belgrade, Belgrade, Serbia; College for Engineering, Mathematics and Physical Sciences, University of Exeter, United Kingdom; Hydro-Informatics Institute, Thailand; Asian Institute of Technology, Thailand},
	abstract = {The intensity and frequency of hydro-meteorological hazards have increased due to fast-growing urbanisation activities and climate change. Hybrid approaches that combine grey infrastructure and Nature-Based Solutions (NBSs) have been applied as an adaptive and resilient strategy to cope with climate change uncertainties and incorporate other co-benefits. This research aims to investigate the feasibility of Real Time Control (RTC) for NBS operation in order to reduce flooding and improve their effectiveness. The study area is the irrigation and drainage system of the Rangsit Area in Thailand. The results show that during the normal flood events, the RTC system effectively reduces water level at the Western Raphiphat Canal Station compared to the system without RTC or with additional storage. Moreover, the RTC system facilitates achieving the required minimum volume and increasing the volume in the retentions. These findings highlight the potential of using RTC to improve the irrigation and drainage system operation as well as NBS implementation to reduce flooding. The RTC system can also assists in equitable water distribution between Klongs and retention areas, while also increasing the water storage in the retention areas. This additional water storage can be utilized for agricultural purposes, providing further benefits. These results represent an essential starting point for the development of Smart Solutions and Digital Twins in utilizing Real-Time Control for flood reduction and water allocation in the Rangsit Area in Thailand. © 2023 The Authors},
	author_keywords = {Digital twins; Flooding; Hybrid measures; Irrigation system; NBS; Real-time control},
	keywords = {Climate Change; Floods; Thailand; Uncertainty; Water; Thailand; Climate change; Drainage; Floods; Irrigation; Water levels; Water supply systems; water; Floodings; Hybrid measure; Irrigation and drainage systems; Irrigation systems; Nature-based solution; Real time control systems; Real-time control; Retention areas; Smart solutions; Thailand; climate change; drainage network; flood control; flooding; infrastructure planning; irrigation system; real time; urbanization; Article; climate change; control strategy; digital twin; feedback system; flooding; hydrodynamics; hydrology; irrigation (agriculture); meteorology; natural science; Thailand; water depth; water supply; climate change; flooding; uncertainty; Real time control},
	correspondence_address = {L. Ruangpan; Faculty of Applied Science, Delft University of Technology, Netherlands; email: l.ruangpan@tudelft.nl},
	publisher = {Academic Press},
