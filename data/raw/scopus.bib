	doi = {10.1016/j.rcns.2024.11.001},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85209748440&doi=10.1016%2Fj.rcns.2024.11.001&partnerID=40&md5=6592e9713a3f5b8cd2d1c25fe9bbafe4},
	affiliations = {Department of Civil & Architectural Engineering, University of Miami, Coral Gables, 33146, FL, United States; School of Architecture, University of Miami, Coral Gables, 33126, FL, United States; Department of Computer Science, University of Miami, Coral Gables, 33146, FL, United States; Systems Engineering, Cornell University, Ithaca, 14853, NY, United States; School of Civil and Environmental Engineering, Cornell University, Ithaca, 14853, NY, United States},
	abstract = {With the ability to harness the power of big data, the digital twin (DT) technology has been increasingly applied to the modeling and management of structures and infrastructure systems, such as buildings, bridges, and power distribution systems. Supporting these applications, an important family of methods are based on graphs. For DT applications in modeling and managing smart cities, large-scale knowledge graphs (KGs) are necessary to represent the complex interdependencies and model the urban infrastructure as a system of systems. To this end, this paper develops a conceptual framework: Automated knowledge Graphs for Complex Systems (AutoGraCS). In contrast to existing KGs developed for DTs, AutoGraCS can support KGs to account for interdependencies and statistical correlations across complex systems. The established KGs from AutoGraCS can then be easily turned into Bayesian networks for probabilistic modeling, Bayesian analysis, and adaptive decision supports. Besides, AutoGraCS provides flexibility in support of users’ need to implement the ontology and rules when constructing the KG. With the user-defined ontology and rules, AutoGraCS can automatically generate a KG to represent a complex system consisting of multiple systems. The bridge network in Miami-Dade County, FL is used as an illustrative example to generate a KG that integrates multiple layers of data from the bridge network, traffic monitoring facilities, and flood water watch stations. © 2024},
	author_keywords = {Bayesian network; Infrastructure systems; Knowledge Graph; System digital twin},
	keywords = {Decision support systems; Flood control; Hierarchical systems; Knowledge graph; Large scale systems; Model buildings; Network theory (graphs); Ontology; Systems analysis; Bayesia n networks; Bridge networks; Infrastructure systems; Knowledge graphs; Management of structures; Ontologies and rules; Power; Structure systems; System applications; System digital twin; Bayesian networks},
