	keywords = {Data acquisition; Data visualization; Decision support systems; Digital storage; Environmental technology; Semantics; Sustainable development; Urban planning; City management; Data quality; Deep impact; Disruptive technology; Environmental sustainability; Sustainable smart city; Systematic literature review; Systematic Review; Technological advancement; Urban digital twin; implementation process; infrastructural development; smart city; sustainability; technological development; urban development; urban planning; Smart city},
