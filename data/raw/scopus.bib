	note = {Cited by: 9; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{ElSayed2024,
	author = {ElSayed, Mo and Mohamed, Moataz},
	title = {Robust digital-twin airspace discretization and trajectory optimization for autonomous unmanned aerial vehicles},
	year = {2024},
