	title = {Structuring heterogeneous urban data: A framework to develop the data model for energy simulation of cities},
	year = {2023},
	journal = {Energy and Buildings},
	volume = {296},
	pages = {},
	doi = {10.1016/j.enbuild.2023.113376},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85165995062&doi=10.1016%2Fj.enbuild.2023.113376&partnerID=40&md5=bb132437cbe4fb04458aa223da5d11bf},
	affiliations = {Department of Building, Civil and Environmental Engineering, Concordia University, Montreal, H3G 1M8, QC, Canada; Department of Electrical and Computer Engineering, Concordia University, Montreal, Canada; Department of Fine Arts, Individualized Program, Concordia University, Montreal, Canada; Gina Cody School of Computer Science and Software Engineer, Concordia University, Montreal, H3G 1M8, QC, Canada; Canada Excellence Research Chair on Smart, Sustainable and Resilient Cities and Communities, Canada},
	abstract = {Globally, there is accelerating interest in cities and the analysis of their underlying systems to understand, project, and propose sustainable energy transformations. These urban areas represent a complex combination of heterogeneous data, which complicates the process of engineering modeling and predicting changes that could occur. Identifying the data sources related to the urban objects and their associated characteristics is essential. While some schemas are developed to collect, consolidate, and organize the required data, such as CityGML, to describe urban geometry semantically, they lack the capability to include different use cases and objectives to adequately parametrize simulation models. There is a lack of a well-structured framework for data modeling to efficiently organize the dispersed data needed for urban energy simulation. This article proposes a framework to develop urban data models connecting with urban energy modeling tools for energy assessments in the city context. The paper's main contribution is presenting a novel implementation methodology for processing, modeling, capturing the results, and populating other existing standard data formats. The data model represents a key element in a novel urban simulation platform and aims at real-time capturing, storing, and investigating the various aspects of city-scale behavior and performance. © 2023},
	author_keywords = {Data interoperability; Data modeling; Decarbonizing Cities; Digital twins; Urban energy modeling},
	keywords = {Energy management; Information analysis; Interoperability; Data interoperability; Data modeling; Decarbonising; Decarbonizing city; Energy model; Energy simulation; Sustainable energy; Underlying systems; Urban energy; Urban energy modeling; Simulation platform},
	correspondence_address = {S. Dabirian; Department of Building, Civil and Environmental Engineering, Concordia University, Montreal, H3G 1M8, Canada; email: sanam.dabirian@mail.concordia.ca},
	publisher = {Elsevier Ltd},
	issn = {03787788},
	coden = {ENEBD},
	language = {English},
	abbrev_source_title = {Energy Build.},
	type = {Article},
