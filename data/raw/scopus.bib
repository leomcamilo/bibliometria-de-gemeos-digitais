}

@ARTICLE{Ruangpan2023,
	author = {Ruangpan, Laddaporn and Mahgoub, Mosaab and Abebe, Yared Abayneh and Vojinovic, Zoran and Boonya-aroonnet, Surajate and Torres, Arlex Sanchez and Weesakul, Sutat},
	title = {Real time control of nature-based solutions: Towards Smart Solutions and digital twins in Rangsit Area, Thailand},
	year = {2023},
	journal = {Journal of Environmental Management},
