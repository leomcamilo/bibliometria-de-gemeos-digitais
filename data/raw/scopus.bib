	doi = {10.3390/rs13101889},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85106470066&doi=10.3390%2Frs13101889&partnerID=40&md5=55a8eff910cd2cb169bdad78dca2b423},
	affiliations = {School of Design and the Built Environment, Curtin University, Bentley, 6102, WA, Australia},
	abstract = {The development of a smart city and digital twin requires the integration of Building Information Modeling (BIM) and Geographic Information Systems (GIS), where BIM models are to be integrated into GIS for visualization and/or analysis. However, the intrinsic differences between BIM and GIS have led to enormous problems in BIM‐to‐GIS data conversion, and the use of City Geography Markup Language (CityGML) has further escalated this issue. This study aims to facilitate the use of BIM models in GIS by proposing using the shapefile format, and a creative approach for converting Industry Foundation Classes (IFC) to shapefile was developed by integrating a computer graphics technique. Thirteen building models were used to validate the proposed method. The result shows that: (1) the IFC‐to‐shapefile conversion is easier and more flexible to realize than the IFC‐to‐CityGML conversion, and (2) the computer graphics technique can improve the efficiency and reliability of BIM‐to‐GIS data conversion. This study can facilitate the use of BIM information in GIS and benefit studies working on digital twins and smart cities where building models are to be processed and integrated in GIS, or any other studies that need to manipulate IFC geometry in depth. © 2021 by the authors. Licensee MDPI, Basel, Switzerland.},
	author_keywords = {3D model; Building Information Modeling (BIM); Digital twin; Geographic Information System (GIS); Industry Foundation Classes (IFC); Smart city},
	keywords = {Architectural design; Computer graphics; Digital twin; Geographic information systems; Markup languages; Smart city; Bim models; Building Information Model - BIM; Building model; Converting industries; Efficiency and reliability; Geography Markup Language; GIS data; Intrinsic differences; Data integration},
