}

@ARTICLE{Chioni2023,
	author = {Chioni, Chiara and Maragno, Anna and Pianegonda, Angelica and Ciolli, Marco and Favargiotti, Sara and Massari, Giovanna A.},
	title = {Low-Cost 3D Virtual and Dynamic Reconstruction Approach for Urban Forests: The Mesiano University Park},
	year = {2023},
