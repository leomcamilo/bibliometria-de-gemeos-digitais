	keywords = {Clustering algorithms; Computational efficiency; Cost effectiveness; Extraction; Geometry; Laser applications; Life cycle; 3D point cloud; 3d point cloud data; Condition assessments; Geometric digital twin; Geometric feature extraction; Pipe networks; Point cloud data; Quantitative condition assessment; Quantitative conditions; Urban pipe network; assessment method; data set; machine learning; pipeline; underground construction; Pipelines},
	correspondence_address = {X. Feng; Faculty of Infrastructure Engineering, Dalian University of Technology, Dalian, China; email: fengxin@dlut.edu.cn},
	publisher = {Elsevier Ltd},
