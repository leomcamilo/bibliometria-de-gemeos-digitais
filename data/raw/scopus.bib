	publisher = {Academic Press},
	issn = {10848045},
	language = {English},
	abbrev_source_title = {J Network Comput Appl},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 12; All Open Access; Hybrid Gold Open Access}
}

