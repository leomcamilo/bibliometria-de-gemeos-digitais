	year = {2025},
	journal = {IEEE Journal of Selected Topics in Applied Earth Observations and Remote Sensing},
	volume = {18},
	pages = {27905 - 27922},
	doi = {10.1109/JSTARS.2025.3623656},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105019803692&doi=10.1109%2FJSTARS.2025.3623656&partnerID=40&md5=eeb0094c3fe5b243be1daa736af1ee03},
	affiliations = {Shanxi University, School of Computer and Information Technology, Key Laboratory of Computational Intelligence and Chinese Information Processing of Ministry of Education, Taiyuan, 030006, China; National Yunlin University of Science and Technology, International Graduate Institute of Artificial Intelligence, Douliou, 64002, Taiwan; Islamic University of Madinah, Faculty of Computer and Information Systems, Medina, 42351, Saudi Arabia; University of Tabuk, Faculty of Computers and Information Technology, Tabuk, 71491, Saudi Arabia},
	abstract = {Urban fire prevention, as a critical global challenge, demands breakthroughs in the daily risk prediction to address the urgent needs of proactive mitigation. However, existing approaches face three bottlenecks: the uncertainty of risk, the real-time coordination of multicity fire data, and the integration of heterogeneous urban perspectives. To overcome these challenges, which are conceptualized as a group consensus problem, this article proposes a digital twin (DT)-driven large-scale group decision-making (LSGDM) framework. The framework integrates four interconnected logical loops: First, a DT model for urban fires is developed using spatial-temporal satellite remote sensing data (STSRSD), enabling dynamic fire risk simulations and STSRSD fusion. Second, an improved Leiden algorithm incorporating an social influence index (SII) and trust thresholds is designed to cluster cities by risk characteristics, reducing intercluster heterogeneity. Third, decision-making roles (leaders/followers) are assigned based on hesitancy levels and SII metrics, with a bidirectional communication mechanism amplifying the influence of key cities. Fourth, this article integrates the strengths of the social network DeGroot (SNDG) model and three-dimensional (3-D) Deffuant–Weisbuch dynamics to propose a hybrid opinion dynamics (HOD) with a two-stage confidence and collaboration-based consensus reaching process (CC-CRP), termed HOD-CC-CRP. Finally, the feasibility of this article is verified through a case study of selected urban fires in China. © 2008-2012 IEEE.},
	author_keywords = {DeGroot model; digital twin (DT); group decision-making; remote sensing; social network},
	keywords = {China; 3D modeling; Decision making; Digital twin; Dynamics; Fires; Social networking (online); Three dimensional computer graphics; Degroot model; Fire risks; Group Decision Making; Opinion dynamics; Remote-sensing; Risk predictions; Satellite remote sensing data; Social network; Spatial temporals; Urban fire; decision making; digitization; fire management; hazard management; remote sensing; risk assessment; satellite data; social network; spatiotemporal analysis; urban area; Remote sensing},
