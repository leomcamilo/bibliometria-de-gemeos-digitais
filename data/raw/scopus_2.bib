@ARTICLE{Zhao202523840,
	author = {Zhao, Yan and Liu, Bingrong and Zhu, Huiru and Luo, Taige and Li, Mingshi},
	title = {LSTD-YOLO: A Lightweight Crowd Density Detection Method for Park Environmental Carrying Capacity Monitoring and Early Warning},
	year = {2025},
	journal = {IEEE Journal of Selected Topics in Applied Earth Observations and Remote Sensing},
	volume = {18},
	pages = {23840 - 23857},
	doi = {10.1109/JSTARS.2025.3607697},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105015519000&doi=10.1109%2FJSTARS.2025.3607697&partnerID=40&md5=2b3a2d073743e046a047558820116a75},
	affiliations = {Jiangsu Open University, College of Rural Revitalization, Nanjing, 210039, China; Hefei University of Technology, School of Software, Hefei, 230601, China; Virginia Tech, Department of Geography, College of Natural Resources and Environment, Blacksburg, 24061, United States; Nanjing Forestry University, College of Forestry, Nanjing, 210037, China; Nanjing Forestry University, Co-Innovation Center for Sustainable Forestry in Southern China, Nanjing, 210037, China},
	abstract = {With the rise of digital twins and smart cities, intelligent park management increasingly demands accurate real-time monitoring of visitor density to support spatial planning and policy decisions. Traditional methods primarily focus on total visitor counts, limiting their ability to capture instantaneous density, particularly in scenarios with uneven population distribution. Although unmanned aerial vehicle (UAV)-based monitoring has attracted attention for its mobility and wide field of view, it has struggled with small-target detection and limited onboard computational resources. To address these challenges, a lightweight object detection model named lightweight small target detection YOLO (LSTD-YOLO) was proposed for identifying small-scale pedestrians in UAV imagery. The model was enhanced with a small target feature fusion module and an additional detection layer to improve fine-grained feature extraction. In addition, the scale-based dynamic loss function was adopted to provide better supervision for small objects. Structured pruning and knowledge distillation were further employed to balance accuracy and efficiency, significantly reducing model complexity with minimal performance degradation. Experiments conducted on the CrowdDensity dataset demonstrate that the pruned LSTD-YOLO outperformed YOLOv11s, with the F1 score improved by 11.2%, mAP50 by 11.71%, and mAP50-95 by 5.32%, accompanied by only a modest 30% increase in GFLOPs. The proposed model also surpasses several state-of-the-art lightweight detectors. To facilitate future research, a high-quality UAV dataset named CrowdDensity has been released, comprising 41 684 annotated small pedestrian instances collected from nine urban parks in Nanjing. © 2008-2012 IEEE.},
	author_keywords = {Environmental carrying capacity; lightweight network; small object detection; tourist monitoring; unmanned aerial vehicle (UAV) remote sensing},
	keywords = {China; Jiangsu; Nanjing [Jiangsu]; Aircraft detection; Decision making; Digital twin; Feature extraction; Object detection; Object recognition; Smart city; Unmanned aerial vehicles (UAV); Capacity monitoring; Crowd density; Density detections; Detection methods; Early warning; Environmental carrying capacities; Lightweight network; Small object detection; Tourist monitoring; UAV remote sensing; carrying capacity; detection method; environmental monitoring; park management; pedestrian; remote sensing; tourist behavior; unmanned vehicle; Distillation; Remote sensing},
	correspondence_address = {M. Li; Nanjing Forestry University, College of Forestry, Nanjing, 210037, China; email: nfulms@njfu.edu.cn},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
