@ARTICLE{Llagostera-Brugarola2025,
	author = {Llagostera-Brugarola, Eudald and Corpas-Marco, Elisabeth and Victorio-Vergel, Carla and Lopez-Aguilera, Elena and Vázquez-Gallego, Francisco and Alonso-Zarate, Jesus},
	title = {A Digital Twin for Intelligent Transportation Systems in Interurban Scenarios},
	year = {2025},
	journal = {Applied Sciences (Switzerland)},
	volume = {15},
	number = {13},
	pages = {},
	doi = {10.3390/app15137454},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010327431&doi=10.3390%2Fapp15137454&partnerID=40&md5=4c8ebba759979e274c27b9d8db75139a},
	affiliations = {Fundació i2CAT, Barcelona, 08034, Spain; Department of Network Engineering, Universitat Politècnica de Catalunya, Barcelona, 08034, Spain},
	abstract = {Digital Twins (DTs) are becoming essential tools for real-time decision-making in transportation systems. This paper presents a macroscopic traffic digital twin developed for a 50 km segment of the C-32 interurban highway in Spain. The digital twin replicates highway conditions using real-time data from roadside sensors and connected vehicles via Vehicle-to-Everything (V2X) communications. It supports intelligent decision-making for traffic management, particularly during incident situations, by recommending macroscopic strategies such as variable speed limits and re-routing. Unlike many existing DTs focused on microscopic modeling or urban contexts, our approach emphasizes a macroscopic scale suitable for interurban highways, enabling faster computation and system-wide insights. The decision-making module evaluates candidate strategies using real-time simulations and selects the most effective option based on key performance indicators (KPIs), including congestion, travel time, and emissions. The system has been validated under realistic traffic scenarios using historical data, considering both congestion and pollution use cases. Strategies are communicated back to the physical infrastructure via V2I messages (IVIM) and a mobile application using the cellular communication network, enabling a closed-loop architecture. This paper contributes a scalable, real-time, and field-integrated macroscopic DT framework for highway traffic management. © 2025 by the authors.},
	author_keywords = {digital twin; Intelligent Transportation Systems (ITS); V2X communications; variable speed limits (VSL)},
	keywords = {Advanced traffic management systems; Decision making; Digital twin; Highway administration; Highway planning; Highway traffic control; Motor transportation; Network architecture; Street traffic control; Traffic congestion; Vehicle to vehicle communications; Wireless networks; Intelligent transportation system; Intelligent transportation systems; Interurban highway; Real time decision-making; Real-time decision making; Traffic management; Transportation system; V2X communication; Variable speed limit; Variable speed limits; Travel time},
