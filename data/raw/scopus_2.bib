}

@ARTICLE{Chauhan202628994,
	author = {Chauhan, Shishir Singh and Jha, Vijay Kumar and Gupta, Gauri Shanker},
	title = {A Four-Phase Spatio-Temporal and Quantum-Enhanced Framework for Traffic Speed Forecasting With Calibrated Uncertainty},
	year = {2026},
	journal = {IEEE Access},
