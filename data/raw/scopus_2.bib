	affiliations = {Grainger College of Engineering, University of Illinois Urbana-champaign, Champaign, Urbana, 61802, United States; School of Engineering and Built Environment, Universiti Teknologi Malaysia, Johor Bahru, Johor, 81310, Malaysia},
