	keywords = {Bohai Rim; Bohai Sea; China; Pacific Ocean; Yellow Sea; climate change; ecosystem resilience; empowerment; entropy; heterogeneity; panel data; spatiotemporal analysis; sustainable development; urban area; water supply},
