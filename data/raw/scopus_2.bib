@ARTICLE{Kavousi-Fard2025,
	author = {Kavousi-Fard, Abdollah and Dabbaghjamanesh, Morteza and Sheikh, Morteza and Jin, Tao},
	title = {A novel deep learning based digital twin model for mitigating wake effects in wind farms},
	year = {2025},
	journal = {Renewable Energy Focus},
	volume = {53},
	pages = {},
