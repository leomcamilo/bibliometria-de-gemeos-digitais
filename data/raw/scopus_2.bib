	keywords = {Advanced traffic management systems; Advanced traveler information systems; Convolution; Flow graphs; Highway traffic control; Information management; Motor transportation; Street traffic control; Traffic congestion; Weather forecasting; Weather information services; Convolutional networks; Dual graphs; Graph convolutional network; Holographic digital twin; IoT consumer electronic; Smart transportation system; Temporal convolutional network; Traffic flow prediction; Transportation system; Decision making},
