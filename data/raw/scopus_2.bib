	keywords = {Automobile drivers; Digital twin; Distributed computer systems; Intelligent vehicle highway systems; Motor transportation; Real time systems; Throughput; Traffic control; Urban transportation; Conceptual model; Connected mobility; Digital twin; Intelligent transportation system; Intelligent transportation systems; Latency compensations; Parallel SUMO execution; Predictive simulations; Speed coordination; Urban traffic; Decision making},
