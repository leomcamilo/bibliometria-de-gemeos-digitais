	language = {English},
	abbrev_source_title = {IEEE J. Sel. Top. Appl. Earth Obs. Remote Sens.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access; Green Open Access}
}

