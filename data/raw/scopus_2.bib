	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105019509292&doi=10.1016%2Fj.scs.2025.106905&partnerID=40&md5=2f7bcf292d72a891f0e1a7bf96f32120},
	affiliations = {School of Architecture and Urban Studies, Department of Urban Planning and Design, University of Art, Postal address: Bagh-e Melli College, No. 58, Sakhai St, Tehran, Iran, Tehran, Iran; School of Architecture & Environmental Design, Department of Urban Planning and Design, Iran University of Science & Technology (IUST), Postal address: Iran University of Science and Technology, Resalat Square, Hengam Street, Tehran, Tehran, Iran; School of Architecture & Environmental Design, Iran University of Science & Technology (IUST), Postal address: Iran University of Science and Technology, Resalat Square, Hengam Street, Tehran, Tehran, Iran},
	abstract = {The concurrent growth of big data and the Internet of Things (IoT) has transformed the urban digital twin into a key tool for planning, design, and management. Yet the gap between technical infrastructure and effective citizen participation remains under-addressed. We ask: (1) which technical and social factors determine the efficiency of urban digital twins, and how these align with Arnstein's participation ladder; and (2) how Tehran compares with leading cities in socio-technical convergence. We conduct a systematic review of 84 sources to derive a two-dimensional framework linking three clusters—data and infrastructure, structural openness, and participation level—and define twelve indicators weighted via the Analytic Hierarchy Process (AHP). We apply the index to nine city-scale twins and then run robustness checks (equal-weight, policy-priority, leave-one-out), which yield rank-order correlations > 0.90, indicating stable comparative findings. Results place Singapore (8.7/10) and Zurich (8.2/10) at the top and Tehran at 4.1, with the largest gaps in open-data governance and participation. We propose a context-sensitive roadmap for Tehran that combines (i) an open 3D data portal, (ii) participatory APIs and low-cost sensing, and (iii) interactive scenario tools, together with digital-literacy programs, privacy-by-design, and trust-building governance. Arnstein's ladder is treated as a heuristic adapted to Tehran's context. Overall, the full potential of urban digital twins is realized only when investments in data infrastructure advance in tandem with transparent governance and citizen empowerment to deliver sustainability outcomes. © 2025 Elsevier Ltd},
	author_keywords = {Citizen participation; Data governance; Digital twin; Smart Tehran; Urban open data},
	keywords = {Iran; Tehran [Iran]; Tehran [Tehran (PRV)]; Analytic hierarchy process; Application programming interfaces (API); Big data; Digital twin; Information management; Internet of things; Investments; Open Data; Scales (weighing instruments); Urban growth; Citizen's participations; Data governances; Planning designs; Planning management; Smart tehran; Sociotechnical; Technical factors; Technical frameworks; Technical infrastructure; Urban open data; analytical hierarchy process; governance approach; infrastructure planning; local participation; satellite data; urban design; urban policy; Ladders},
	correspondence_address = {F. Shariatpour; School of Architecture and Urban Studies, Department of Urban Planning and Design, University of Art, Postal address: Bagh-e Melli College, No. 58, Sakhai St, Tehran, Iran, Tehran, Iran; email: farshad_shariatpour@alumni.iust.ac.ir},
