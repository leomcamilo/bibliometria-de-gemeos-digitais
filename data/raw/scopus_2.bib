	affiliations = {School of Electrical Engineering and Informatics, Institut Teknologi Bandung, Bandung, 40132, Indonesia; Faculty of Geography, Universitas Gadjah Mada, Yogyakarta, 55281, Indonesia; Faculty of Computer Science, University of Indonesia, Jakarta, 16424, Indonesia},
