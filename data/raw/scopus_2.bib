	affiliations = {Artificial Intelligence Research Institute, Shenzhen MSU-BIT University, Shenzhen, China; Guangdong Engineering Center for Social Computing and Mental Health, Shenzhen, China; Wuda Geoinformatics co., Ltd., Wuhan, China; Faculty of Engineering, Shenzhen MSU-BIT University, Shenzhen, China},
	abstract = {Digital twin technologies are reshaping smart city development by enabling precise and efficient urban modeling. However, traditional photogrammetry-based 3D reconstruction methods face challenges such as high computational costs, redundant data, and limited semantic details, which restrict their scalability. To overcome these limitations, we propose an automated framework for modeling urban elements, including buildings, water bodies, roads, and vegetation, using oblique photogrammetry data. The framework integrates advanced AI-driven semantic segmentation, geometric simplification, horizontal slicing for building extraction, and texture mapping to produce lightweight, individualized models. A key innovation of this framework lies in its precise modeling of both vegetation and buildings. For vegetation, the framework employs neural network classification, random point distribution, and 3D engine-based elevation sampling to generate accurate digital twin models. For buildings, horizontal slicing is used to efficiently reconstruct 3D structures by segmenting and refining characteristic surfaces. This approach reduces data volume by over 80% while preserving visual fidelity, facilitating large-scale scene rendering and interactive simulations. The proposed framework has been successfully applied to the Jingdezhen digital twin project, covering 1300 km<sup>2</sup>, demonstrating its effectiveness in large-scale urban reconstruction. Applications include urban planning, ecological monitoring, and low-altitude economic activities such as drone logistics. By enhancing automation, scalability, and semantic integration, this framework provides a robust foundation for building digital twin cities to support urban management and decision-making. © 2025 John Wiley & Sons Ltd.},
	author_keywords = {3D modeling; AI-driven semantic segmentation; digital twin city; oblique photogrammetry},
	keywords = {China; Jiangxi; Jingdezhen; 3D modeling; 3D reconstruction; Decision making; Digital twin; Ecology; Neural networks; Photogrammetry; Semantic Segmentation; Semantic Web; Semantics; Smart city; Three dimensional computer graphics; Urban growth; 3D models; 3d-modeling; AI-driven semantic segmentation; Digital twin city; Element method; Large-scales; Oblique photogrammetry; Semantic segmentation; Urban elements; Urban modeling; artificial intelligence; data processing; decision making; GIS; photogrammetry; remote sensing; smart city; three-dimensional modeling; urban planning; Scalability},
