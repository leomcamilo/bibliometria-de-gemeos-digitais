	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105020964007&doi=10.1109%2FTCE.2025.3627965&partnerID=40&md5=82c666eb166e3ed1fe42c18c3dccedc4},
	affiliations = {Department of Management Information Systems, College of Business, Jazan University, Jazan, 45142, Saudi Arabia},
	abstract = {The growing integration of IoT consumer electronics into urban infrastructure has led to the generation of vast amounts of real-time data from traffic sensors, weather stations, and connected devices. By combining traffic flow information with weather conditions and their holographic digital twin counterparts, cities can improve congestion management under varying environmental scenarios. However, most existing traffic flow prediction models overlook the latent spatial relationships within transportation networks and fail to address prediction errors caused by external factors such as weather, reducing forecast accuracy. To overcome these limitations, this paper introduces the Holographic Digital Twin Graph Convolutional Network (HDT-GCN), a dual-graph convolution framework built on Temporal Convolutional Networks (TCNs) to fuse traffic flow and weather features into an augmented representation. This approach jointly models temporal dependencies, spatial correlations, and dynamic inter-regional interactions, while mitigating the negative impact of complex weather patterns on prediction outcomes. The incorporation of holographic digital twins enhances system visualization, real-time decision-making, and interactive accessibility through IoT consumer devices. Extensive experiments on the real-world TaxiBJ and PeMSD4 datasets demonstrate that HDT-GCN achieves superior prediction accuracy and robustness compared to state-of-the-art methods. © 1975-2011 IEEE.},
