@ARTICLE{Fan2025,
	author = {Fan, Chenchen and Hou, Jingming and Li, Xuan and Song, Gangfu and Yang, Yihui and Liang, Xin and Zhou, Qingshi and Imran, Muhammad and Chen, Guangzhao and Wang, Ziyi and Lu, Pinpin},
	title = {Efficient urban flood control and drainage management framework based on digital twin technology and optimization scheduling algorithm},
	year = {2025},
	journal = {Water Research},
	volume = {282},
	pages = {},
	doi = {10.1016/j.watres.2025.123711},
