@ARTICLE{Zhang2025,
	author = {Zhang, Yaqi and Ji, Chunyu and Ye, Jing and Zou, Heng and Peng, Lanjia},
	title = {Architectural identity in smart city development: a multi-criteria study on regional culture in northeastern China},
	year = {2025},
	journal = {Journal of Asian Architecture and Building Engineering},
	pages = {},
	doi = {10.1080/13467581.2025.2560455},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105017091477&doi=10.1080%2F13467581.2025.2560455&partnerID=40&md5=93c13cce210cd283d71023be92e7968d},
	affiliations = {School of Chinese Languages & Literatures, Lanzhou University, Gansu, Lanzhou, China; School of Marxism, Central University of Finance and Economics, Beijing, China; Department of Film Media Content, Cheongju University, Cheongju, South Korea},
	abstract = {In northern China, smart city infrastructure development is directly affected by the cultural aspects of the region, and there is a need for a futuristic strategy to make decisions that complement tradition with technology. The current study attempts to show the way how MCDM frameworks and digital twin technology are combined to influence urban planning and infrastructure optimization concerning cultural issues. The current study is about how regional culture influences smart city infrastructure development in northeastern China through a survey-based approach. This research study investigates how cultural values, governance models, and socio-economic conditions influence smart city development by collecting information from urban planners, policymakers, architects, and residents of key cities. The questionnaire aimed to identify stakeholder perceptions regarding integrating traditional architectural elements, local institutional frameworks, and new technologies, such as digital twins and artificial intelligence, into urban planning. The study employs multi-criteria decision-making (MCDM) methods to examine the importance of relevance and cultural weightage in the selection of a decision-making framework for development that is aimed at optimizing infrastructure, sustainability, and efficiency. Surveys confirm technology acceptance, but preference toward regional identity through adaptive strategies takes precedence in urban planning. This research shows how computational intelligence aids the differential urban transformation under uncertainty pertaining to decision-making while keeping an eye on culture. Challenges confronting the smart city development processes in the region are those such as change management, gaps in policy, and technological accessibility. The findings suggest that the MCDM’s hybrid decision support systems with stakeholder consultations could enhance smart city project formulation without compromising heritage. © 2025 The Author(s). Published by Informa UK Limited, trading as Taylor & Francis Group on behalf of the Architectural Institute of Japan, Architectural Institute of Korea and Architectural Society of China.},
	author_keywords = {digital twin technology; MCDM; regional culture; Smart city infrastructure; stakeholder perceptions},
	keywords = {Architecture; Artificial intelligence; Decision making; Digital twin; Regional planning; Smart city; Sustainable city; Sustainable development; Urban growth; 'current; Digital twin technology; Infrastructure development; Multi criteria decision-making; Multi-Criterion; Multicriteria decision-making; Multicriterion decision makings; Regional cultures; Smart city infrastructure; Stakeholder perception; Decision support systems},
	correspondence_address = {H. Zou; Department of Film Media Content, Cheongju University, Cheongju, 298 Daeseong-ro, Cheongwon-gu, Chungcheongbuk-do, South Korea; email: zouheng0608@gmail.com},
	publisher = {Taylor and Francis Ltd.},
	issn = {13467581},
	language = {English},
	abbrev_source_title = {J. Asian Archit. Build. Eng.},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Deng202158,
	author = {Deng, Min and Menassa, Carol C. and Kamat, Vineet R.},
	title = {From BIM to digital twins: A systematic review of the evolution of intelligent building representations in the AEC-FM industry},
	year = {2021},
	journal = {Journal of Information Technology in Construction},
	volume = {26},
	pages = {58 - 83},
	doi = {10.36680/J.ITCON.2021.005},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85103484819&doi=10.36680%2FJ.ITCON.2021.005&partnerID=40&md5=ea9dc898148ed6e9b317ca3079cfaaae},
	affiliations = {Department of Civil and Environmental Engineering, University of Michigan, United States},
	abstract = {The widespread adoption of Building Information Modeling (BIM) and the recent emergence of Internet of Things (IoT) applications offer several new insights and decision-making capabilities throughout the life cycle of the built environment. In recent years, the ability of real-time connectivity to online sensors deployed in an environment has led to the emergence of the concept of the Digital Twin of the built environment. Digital Twins aim to achieve synchronization of the real world with a virtual platform for seamless management and control of the construction process, facility management, environment monitoring, and other life cycle processes in the built environment. However, research in Digital Twins for the built environment is still in its nascent stages and there is a need to understand the advances in the underlying enabling technologies and establish a convergent context for ongoing and future research. This paper conducted a systematic review to identify the development of the emerging technologies facilitating the evolution of BIM to Digital Twins in built environment applications. A total of 100 related papers including 23 review papers were selected and reviewed. In order to systematically classify the reviewed studies, the authors developed a five-level ladder categorization system based on the building life cycle to reflect the current state-of-the-art in Digital Twin applications. In each level of this taxonomy, applications were further categorized based on their research domains (e.g., construction process, building energy performance, indoor environment monitoring). In addition, the current state-of-art in technologies enabling Digital Twins was also summarized from the reviewed literature. It was found that most of the prior studies conducted thus far have not fully exploited or realized the envisioned concept of the Digital Twin, and thus classify under the earlier ladder categories. Based on the analysis of the reviewed work and the trends in ongoing research, the authors propose a concept of an advanced Digital Twin for building management as a baseline for further studies. © 2021 The author(s).},
	author_keywords = {Building Information Modeling (BIM); Built Environment; Digital Twin; Internet of Things (IoT); Smart Buildings; Smart City},
	keywords = {Architectural design; Construction; Decision making; Digital twin; Frequency modulation; Intelligent buildings; Internet of things; Ladders; Life cycle; Office buildings; Building energy performance; Building Information Model - BIM; Categorization systems; Emerging technologies; Enabling technologies; Environment monitoring; Internet of Things (IOT); Management and controls; Arts computing},
	publisher = {International Council for Research and Innovation in Building and Construction},
	issn = {18744753},
	language = {English},
	abbrev_source_title = {J. Inf. Technol. Constr.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 378; All Open Access; Gold Open Access}
}

@ARTICLE{Lin2025,
	author = {Lin, Zhengsong and Ji, Zhe and Yuan, Jihui and Zhu, Zunling},
	title = {Research on emotional perception and human comfort evaluation of carbon sequestration landscape design based on digital twin technology},
	year = {2025},
	journal = {Urban Climate},
	volume = {64},
	pages = {},
	doi = {10.1016/j.uclim.2025.102715},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105023659081&doi=10.1016%2Fj.uclim.2025.102715&partnerID=40&md5=596200f6ee8527372ceb0ff848232108},
	affiliations = {College of Art & Design, Nanjing Forestry University, Nanjing, 210037, China; College of Art and Design, Wuhan Institute of Technology, Wuhan, 430205, China; Department of Living Environment Design, of Human Life and Ecology, Osaka Metropolitan University, Osaka, 558-8585, Japan; Jinpu Research institute, Nanjing Forestry University, Nanjing, 210037, China},
	abstract = {In response to the increasing frequency of extreme weather events globally, the Chinese government has proposed the dual‑carbon strategy to mitigate climate change. In this context, optimizing human body comfort and carbon sink capacity has become integral to urban green space design. This study proposes that digital twin design offers a viable framework for future urban carbon sink green space planning. By establishing a digital twin platform, this study utilizes Virtual Reality (VR) to facilitate real-time monitoring of Carbon Sink Capacity (CSC), the Discomfort Index (DI), as well as participants' Eye Movement Interest (EMI) and Skin Conductance Level (SCL) across various Areas of Interest (AOI). The findings indicate that: (1) CSC of different AOI exhibit a positive correlation with the participants' EMI; (2) the participants' level of EMI in different AOI is inversely correlated with SCL; and (3) the participants' SCL in different AOI is positively correlated with DI under human thermal sensation. The research results demonstrate that digital twin platform can be effectively applied to urban green space functional evaluation, providing practical design recommendations conducive to urban carbon sink optimization and achieving dual carbon goals. © 2025 Elsevier B.V.},
	author_keywords = {Carbon sink landscape design; Climate governance; Digital twin technology; Emotional perception; Human thermal comfort},
	correspondence_address = {Z. Zhu; College of Art & Design, Nanjing Forestry University, Nanjing, 210037, China; email: 2023099@njfu.edu.cn},
	publisher = {Elsevier B.V.},
	issn = {22120955},
	language = {English},
	abbrev_source_title = {Urban Clim.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Zhao2025,
	author = {Zhao, Yian and Li, Kangxing and Zhang, Weiping},
	title = {Digital Twin–Based Simulation and Decision-Making Framework for the Renewal Design of Urban Industrial Heritage Buildings and Environments: A Case Study of the Xi’an Old Steel Plant Industrial Park},
	year = {2025},
	journal = {Buildings},
	volume = {15},
	number = {23},
	pages = {},
	doi = {10.3390/buildings15234367},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105024558312&doi=10.3390%2Fbuildings15234367&partnerID=40&md5=eac3ebd86332d06a211099bdd36bce38},
	affiliations = {School of Art, Xi’an University of Architecture and Technology, Xi’an, 710055, China},
	abstract = {In response to the coexistence of multi-objective conflicts and environmental complexity in the renewal of contemporary urban industrial heritage, this study develops a simulation and decision-making methodology for architectural and environmental renewal based on a digital twin framework. Using the Xi’an Old Steel Plant Industrial Heritage Park as a case study, a community-scale digital twin model integrating multiple dimensions—architecture, environment, population, and energy systems—was constructed to enable dynamic integration of multi-source data and cross-scale response analysis. The proposed methodology comprises four core components: (1) integration of multi-source baseline datasets—including typical meteorological year data, industry standards, and open geospatial information—through BIM, GIS, and parametric modeling, to establish a unified data environment for methodological validation; (2) development of a high-performance dynamic simulation system integrating ENVI-met for microclimate and thermal comfort modeling, EnergyPlus for building energy and carbon emission assessment, and AnyLogic for multi-agent spatial behavior simulation; (3) establishment of a comprehensive performance evaluation model based on Multi-Criteria Decision Analysis (MCDA) and the Analytic Hierarchy Process (AHP); (4) implementation of a visual interactive platform for design feedback and scheme optimization. The results demonstrate that under parameter-calibrated simulation conditions, the digital twin system accurately reflects environmental variations and crowd behavioral dynamics within the industrial heritage site. Under the optimized renewal scheme, the annual carbon emissions of the park decrease relative to the baseline scenario, while the Universal Thermal Climate Index (UTCI) and spatial vitality index both show significant improvement. The findings confirm that digital twin-driven design interventions can substantially enhance environmental performance, energy efficiency, and social vitality in industrial heritage renewal. This approach marks a shift from experience-driven to evidence-based design, providing a replicable technological pathway and decision-support framework for the intelligent, adaptive, and sustainable renewal of post-industrial urban spaces. The digital twin framework proposed in this study establishes a validated paradigm for model coupling and decision-making processes, laying a methodological foundation for future integration of comprehensive real-world data and dynamic precision mapping. © 2025 by the authors.},
	author_keywords = {architectural and environmental renewal; design simulation; digital twin; industrial heritage; Xi’an old steel plant},
	keywords = {Analytic hierarchy process; Architectural design; Behavioral research; Computer aided software engineering; Data integration; Decision making; Decision support systems; Digital twin; Energy efficiency; Environmental management; Hierarchical systems; Historic preservation; Industrial emissions; Integration; Sustainable development; Architectural and environmental renewal; Carbon emissions; Case-studies; Decision-making frameworks; Design simulations; Heritage buildings; Industrial heritage; Industrial parks; Multi-Sources; Xi’an old steel plant; Multi agent systems},
	correspondence_address = {W. Zhang; School of Art, Xi’an University of Architecture and Technology, Xi’an, 710055, China; email: zhangweiping@xauat.edu.cn},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
	issn = {20755309},
	language = {English},
	abbrev_source_title = {Buildings},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Xu202530,
	author = {Xu, Tingting and Ma, Haoran and Xu, Nuo and Zhou, Yadong and He, Biao},
	title = {CIM Meets 5G: a Review of Integrated Communication-Sensing Frameworks for Smart City Digital Twins},
	year = {2025},
	journal = {Journal of Geodesy and Geoinformation Science},
	volume = {8},
	number = {3},
	pages = {30 - 52},
	doi = {10.11947/j.JGGS.2025.0303},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105028254797&doi=10.11947%2Fj.JGGS.2025.0303&partnerID=40&md5=b9222aa86f9dcc6aec6a508f06b13b0e},
	affiliations = {School of Computer Science and Technology, Chongqing University of Posts and Telecommunications, Chongqing, 400065, China; Chongqing Branch, China United Network Communications Co., Ltd, Chongqing, 400000, China; School of Architecture and Urban Planning, Shenzhen University, Shenzhen, 518060, China},
	abstract = {The integration of City Information Modeling (CIM) and Fifth-Generation (5G) communication technologies is reshaping the digital infrastructure of smart cities. While CIM provides structured spatial-semantic models for urban representation, 5G enables large-scale, low-latency, and high-bandwidth data exchange. However, their combined application poses challenges in terms of data heterogeneity, semantic interoperability, real-time synchronization, and scalability. This paper presents a systematic review of the core technologies, current gaps, and integration strategies of CIM and 5G. We categorize key architectural patterns, analyze technical limitations in IoT-enabled sensing and communication, and compare the roles of standards such as IFC and CityGML in supporting dynamic CIM updates. Furthermore, we highlight emerging directions, including federated learning, explainable AI, and ISAC (Integrated Sensing and Communication), to support secure and adaptive digital twin platforms. In addition, this research contributes a novel three-layer CIM+5G integration architecture, provides systematic categorization of implementation challenges, and establishes a comprehensive development roadmap spanning network evolution and governance models. Our analysis reveals that a unified, cross-domain CIM+5G framework requires both architectural convergence and semantic extensibility. This study provides practical insights for scalable deployment strategies across cities of varying sizes and lays the groundwork for next-generation urban sensing and communication infrastructures. © 2025, SinoMaps Press. All rights reserved.},
	author_keywords = {5G communication; City Information Model; Smart City},
	publisher = {SinoMaps Press},
	issn = {20965990},
	language = {English},
	abbrev_source_title = {J. Geodesy. Geoinform. Sci.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

